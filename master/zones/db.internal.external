$TTL 300
@   IN  SOA ns1.internal. admin.internal. (
        2026060401 ; serial
        3600       ; refresh
        900        ; retry
        604800     ; expire
        300        ; negative cache TTL
)

@       IN  NS      ns1.internal.
@       IN  NS      ns2.internal.
@       IN  TXT     "course=dns-project;view=external"

ns1     IN  A       203.0.113.2
ns2     IN  A       203.0.113.3
web     IN  A       203.0.113.20
www     IN  CNAME   web.internal.
